# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rnec_user
DB_PASSWORD=rnec_password
DB_DATABASE=rnec_drers

# TypeORM
TYPEORM_LOGGING=true

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DEFAULT=1d
JWT_REFRESH_TTL_EXTENDED=30d

# Email tokens
EMAIL_VERIFY_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60

# Resend
RESEND_API_KEY=
RESEND_FROM="RNEC <noreply@rnec.rw>"
