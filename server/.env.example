# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rnec_user
DB_PASSWORD=rnec_password
DB_DATABASE=rnec_drers

# TypeORM
TYPEORM_LOGGING=true

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DEFAULT=1d
JWT_REFRESH_TTL_EXTENDED=30d

# Email tokens
EMAIL_VERIFY_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60

# Cloudinary
CLOUDINARY_CLOUD_NAME=cloudinary-cloud-name
CLOUDINARY_API_KEY=cloudinary-api-key
CLOUDINARY_API_SECRET=cloudinary-api-secret
CLOUDINARY_DOCUMENTS_FOLDER=rnec/applications/documents

# Resend
RESEND_API_KEY=
RESEND_FROM="RNEC <noreply@rnec.rw>"

# OCR (Ollama)
# Master switch for document OCR. When false the background cron does NOT run
# and no documents are processed. Set to true to enable OCR in this environment.
OCR_CRON_ENABLED=false
# Preferred Ollama endpoint (full URL). If omitted, OLLAMA_HOST is checked next.
OLLAMA_BASE_URL=http://localhost:11434
# Backward-compatible host fallback (host[:port]); used only when OLLAMA_BASE_URL is empty.
OLLAMA_HOST=
OLLAMA_MODEL=qwen2.5vl:7b
OCR_MAX_ATTEMPTS=3
OCR_PDF_MAX_PAGES=20
OCR_TITLE_MATCH_PAGES=3
OCR_IMAGE_MAX_EDGE_PX=1280
OCR_DOWNLOAD_TIMEOUT_MS=45000
OCR_OLLAMA_REQUEST_TIMEOUT_MS=120000
OCR_PROVIDER_HEALTHCHECK_TIMEOUT_MS=5000
OCR_PROVIDER_CHECK_INTERVAL_MS=60000
OCR_PROCESSING_STALE_MINUTES=30
OCR_SIGNED_DELIVERY_ENABLED=true
OCR_SIGNED_DELIVERY_TYPE=authenticated
OCR_SIGNED_URL_TTL_SECONDS=300
OCR_REQUEUE_FAILED_DOWNLOAD_AUTH_ERRORS_ON_BOOT=false
